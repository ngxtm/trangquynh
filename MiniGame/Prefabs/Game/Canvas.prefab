--- !u!114 &1036207119698506580
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 95825668857055914}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 10102, guid: 0000000000000000e000000000000000, type: 0}
    m_FontSize: 30
    m_FontStyle: 0
    m_BestFit: 1
    m_MinSize: 0
    m_MaxSize: 30
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "1. B\u1ED1c v\xE0 r\u1EA3i qu\xE2n\n+ Ng\u01B0\u1EDDi ch\u01A1i b\u1EA5m
    v\xE0o m\u1ED9t trong n\u0103m \xF4 quan thu\u1ED9c b\xEAn m\xECnh \u0111\u1EC3
    b\u1EAFt \u0111\u1EA7u b\u1ED1c qu\xE2n \u1EDF m\u1ED9t \xF4 t\xF9y th\xEDch.\n+
    Nh\u1EA5n ch\u1ECDn h\u01B0\u1EDBng \u0111i tr\xE1i ho\u1EB7c ph\u1EA3i \n+ L\xFAc
    n\xE0y s\u1EBD b\u1ED1c to\xE0n b\u1ED9 s\u1ED1 qu\xE2n t\u1EA1i \xF4 \u0111\u01B0\u1EE3c
    ch\u1ECDn v\xE0 r\u1EA3i theo h\u01B0\u1EDBng \u0111\xE3 ch\u1ECDn m\u1ED7i \xF4
    1 qu\xE2n cho \u0111\u1EBFn khi h\u1EBFt qu\xE2n\n\n2. Khi r\u1EA3i h\u1EBFt
    qu\xE2n \n* N\u1EBFu ti\u1EBFp theo l\xE0 m\u1ED9t \xF4 ch\u1EE9a quan: l\u01B0\u1EE3t
    ch\u01A1i k\u1EBFt th\xFAc, quy\u1EC1n ch\u01A1i \u0111\u01B0\u1EE3c chuy\u1EC3n
    cho ng\u01B0\u1EDDi kia, kh\xF4ng c\xF3 qu\xE2n n\xE0o \u0111\u01B0\u1EE3c \u0103n.\n*
    N\u1EBFu ti\u1EBFp theo l\xE0 \xF4 ch\u1EE9a d\xE2n: Ng\u01B0\u1EDDi ch\u01A1i
    b\u1ED1c t\u1EA5t c\u1EA3 qu\xE2n v\xE0 ti\u1EBFp t\u1EE5c r\u1EA3i qu\xE2n.\n*
    N\u1EBFu \xF4 ti\u1EBFp theo l\xE0 \xF4 tr\u1ED1ng: b\u1EAFt \u0111\u1EA7u qu\xE1
    tr\xECnh \"\u0102n qu\xE2n\".\n\n3. \u0102n qu\xE2n:\n- \u0102n qu\xE2n: \u0103n
    to\xE0n b\u1ED9 s\u1ED1 qu\xE2n \u1EDF sau \xF4 tr\u1ED1ng \n- \u0102n d\xE2y:\n+
    Sau khi \u0103n \u0111\u01B0\u1EE3c m\u1ED9t \xF4, ng\u01B0\u1EDDi ch\u01A1i
    ti\u1EBFp t\u1EE5c x\xE9t \xF4 ti\u1EBFp theo n\u1EEFa.\r\n+ N\u1EBFu \xF4 n\xE0y
    l\u1EA1i l\xE0 m\u1ED9t \xF4 tr\u1ED1ng, ng\u01B0\u1EDDi ch\u01A1i \u0111\u01B0\u1EE3c
    quy\u1EC1n \u0103n ti\u1EBFp qu\xE2n \u1EDF \xF4 n\u1EB1m sau n\xF3.\r\n+ Qu\xE1
    tr\xECnh \"\u0103n d\xE2y\" n\xE0y k\u1EBFt th\xFAc khi g\u1EB7p m\u1ED9t \xF4
    c\xF3 qu\xE2n ho\u1EB7c m\u1ED9t \xD4 Quan.\n- Sau khi \u0103n xong, l\u01B0\u1EE3t
    ch\u01A1i k\u1EBFt th\xFAc v\xE0 chuy\u1EC3n cho ng\u01B0\u1EDDi ch\u01A1i kia.\n\n4.
    Lu\u1EADt \u0111\u1EB7c bi\u1EC7t:\n- M\u1EA5t D\xE2n: V\xE0o \u0111\u1EA7u l\u01B0\u1EE3t
    c\u1EE7a m\xECnh, n\u1EBFu t\u1EA5t c\u1EA3 5 \xD4 D\xE2n c\u1EE7a ng\u01B0\u1EDDi
    ch\u01A1i \u0111\u1EC1u kh\xF4ng c\xF3 qu\xE2n, h\u1ECD ph\u1EA3i h\xE0nh \u0111\u1ED9ng
    nh\u01B0 sau:\r\n+ L\u1EA5y 5 Qu\xE2n D\xE2n t\u1EEB s\u1ED1 \u0111i\u1EC3m \u0111\xE3
    \u0103n \u0111\u01B0\u1EE3c c\u1EE7a m\xECnh ra.\r\n+ \u0110\u1EB7t v\xE0o m\u1ED7i
    \xD4 D\xE2n c\u1EE7a m\xECnh 1 qu\xE2n.\r\n+ Sau \u0111\xF3 ti\u1EBFn h\xE0nh
    l\u01B0\u1EE3t \u0111i nh\u01B0 b\xECnh th\u01B0\u1EDDng.\r\n+ N\u1EBFu ng\u01B0\u1EDDi
    ch\u01A1i kh\xF4ng \u0111\u1EE7 5 qu\xE2n \u0111\u1EC3 r\u1EA3i, h\u1ECD ph\u1EA3i
    vay c\u1EE7a \u0111\u1ED1i ph\u01B0\u01A1ng v\xE0 s\u1EBD tr\u1EA3 l\u1EA1i khi
    \u0103n \u0111\u01B0\u1EE3c qu\xE2n sau n\xE0y.\r\n+ N\u1EBFu c\u1EA3 hai ng\u01B0\u1EDDi
    ch\u01A1i \u0111\u1EC1u kh\xF4ng c\xF3 qu\xE2n \u0111\u1EC3 r\u1EA3i v\xE0 kh\xF4ng
    c\xF2n qu\xE2n trong kho \u0111i\u1EC3m, game k\u1EBFt th\xFAc.\n- R\u1EA3i v\xE0o
    \xF4 xu\u1EA5t ph\xE1t: n\u1EBFu vi\u1EC7c r\u1EA3i qu\xE2n \u0111i m\u1ED9t
    v\xF2ng tr\xF2n v\xE0 quay tr\u1EDF l\u1EA1i \xF4 xu\u1EA5t ph\xE1t ban \u0111\u1EA7u,
    \xF4 n\xE0y s\u1EBD \u0111\u01B0\u1EE3c b\u1ECF qua (kh\xF4ng r\u1EA3i qu\xE2n
    v\xE0o) v\xE0 qu\xE2n s\u1EBD \u0111\u01B0\u1EE3c r\u1EA3i v\xE0o \xF4 ti\u1EBFp
    theo.\t\n\n5. \u0110i\u1EC1u ki\u1EC7n k\u1EBFt th\xFAc game:\nGame k\u1EBFt
    th\xFAc khi m\u1ED9t trong hai \u0111i\u1EC1u ki\u1EC7n sau x\u1EA3y ra:\r\n-
    \u0110i\u1EC1u ki\u1EC7n ch\xEDnh: To\xE0n b\u1ED9 qu\xE2n trong hai \xD4 Quan
    \u0111\xE3 b\u1ECB \u0103n h\u1EBFt.\r\n- \u0110i\u1EC1u ki\u1EC7n ph\u1EE5:
    To\xE0n b\u1ED9 qu\xE2n d\xE2n tr\xEAn b\xE0n c\u1EDD \u0111\xE3 b\u1ECB \u0103n
    h\u1EBFt (kh\xF4ng c\xF2n qu\xE2n trong 10 \xD4 D\xE2n).\n\n6. T\xEDnh \u0111i\u1EC3m
    \n- T\xEDnh \u0111i\u1EC3m: M\u1ED7i ng\u01B0\u1EDDi ch\u01A1i \u0111\u1EBFm
    t\u1ED5ng \u0111i\u1EC3m c\u1EE7a m\xECnh d\u1EF1a tr\xEAn s\u1ED1 qu\xE2n \u0111\xE3
    \u0103n \u0111\u01B0\u1EE3c. \n\tT\u1ED5ng \u0111i\u1EC3m: (s\u1ED1 d\xE2n x
    1) +(s\u1ED1 quan x 10) - s\u1ED1 n\u1EE3 (n\u1EBFu c\xF3).\n- X\xE1c \u0111\u1ECBnh
    ng\u01B0\u1EDDi ch\u01A1i th\u1EAFng:\n+ Ng\u01B0\u1EDDi ch\u01A1i c\xF3 t\u1ED5ng
    \u0111i\u1EC3m cao h\u01A1n s\u1EBD th\u1EAFng.\n+ N\u1EBFu hai ng\u01B0\u1EDDi
    c\xF3 \u0111i\u1EC3m b\u1EB1ng nhau, k\u1EBFt qu\u1EA3 l\xE0 H\xF2a."
